# --- Authentification de l'espace des fiancés ---
# Mot de passe pour accéder au tableau de bord (/admin).
ADMIN_PASSWORD=changez-moi

# Secret utilisé pour signer la session (mettez une longue chaîne aléatoire).
SESSION_SECRET=une-longue-chaine-aleatoire-a-changer

# --- Base de données (Postgres) ---
# En production sur Vercel : ajoutez un stockage Postgres (Neon) depuis
# l'onglet "Storage" du projet, la variable est injectée automatiquement.
# Vous pouvez aussi coller ici une URL Neon/Supabase.
# Sans cette variable, l'app fonctionne en mode démo (stockage local, non persistant).
DATABASE_URL=
